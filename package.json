{
  "name": "tf-tools",
  "displayName": "Trezor Firmware Tools",
  "description": "Build context configuration and tooling for the trezor-firmware repository.",
  "version": "0.1.0",
  "publisher": "trezor",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/tf-tools.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tf-tools",
          "title": "Trezor Firmware Tools",
          "icon": "images/tf-tools-logo.png"
        }
      ]
    },
    "views": {
      "tf-tools": [
        {
          "id": "tfTools.configuration",
          "name": "Configuration",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "tfTools.showLogs",
        "title": "Show Logs",
        "category": "Trezor"
      },
      {
        "command": "tfTools.revealConfiguration",
        "title": "Reveal Configuration View",
        "category": "Trezor"
      }
    ],
    "configuration": {
      "title": "Trezor Firmware Tools",
      "properties": {
        "tfTools.manifestPath": {
          "type": "string",
          "default": "tf-tools.yaml",
          "description": "Path to the tf-tools manifest file, relative to the workspace root.",
          "scope": "resource"
        },
        "tfTools.showConfigurationInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the active build configuration in the status bar.",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/integration/runTest.js",
    "test:unit": "mocha --ui tdd --require out/test/unit/setup.js 'out/test/unit/**/*.test.js'",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.3.2",
    "eslint": "^9.21.0",
    "mocha": "^10.8.2",
    "typescript": "^5.8.2"
  }
}
