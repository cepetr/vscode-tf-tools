{
  "name": "tf-tools",
  "displayName": "Trezor Firmware Tools",
  "description": "Build context configuration and tooling for the trezor-firmware repository.",
  "version": "0.1.0",
  "publisher": "cepetr",
  "repository": {
    "type": "git",
    "url": "https://github.com/cepetr/tf-tools.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "icon": "images/tf-tools-logo.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tf-tools",
          "title": "Trezor",
          "icon": "images/tf-tools.svg"
        }
      ]
    },
    "views": {
      "tf-tools": [
        {
          "id": "tfTools.configuration",
          "name": "Configuration",
          "icon": "images/tf-tools.svg",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "tfTools.showLogs",
        "title": "Show Logs",
        "category": "Trezor"
      },
      {
        "command": "tfTools.build",
        "title": "Build",
        "category": "Trezor",
        "icon": "$(play)"
      },
      {
        "command": "tfTools.clippy",
        "title": "Run Clippy",
        "category": "Trezor",
        "icon": "$(checklist)"
      },
      {
        "command": "tfTools.check",
        "title": "Run Check",
        "category": "Trezor",
        "icon": "$(check-all)"
      },
      {
        "command": "tfTools.clean",
        "title": "Run Clean",
        "category": "Trezor",
        "icon": "$(trash)"
      },
      {
        "command": "tfTools.refreshIntelliSense",
        "title": "Refresh IntelliSense",
        "category": "Trezor",
        "icon": "$(refresh)"
      },
      {
        "command": "tfTools.flash",
        "title": "Flash",
        "category": "Trezor",
        "icon": "$(zap)"
      },
      {
        "command": "tfTools.upload",
        "title": "Upload",
        "category": "Trezor",
        "icon": "$(arrow-up)"
      },
      {
        "command": "tfTools.openMapFile",
        "title": "Open Map File",
        "category": "Trezor",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "tfTools.flash",
          "when": "tfTools.flashApplicable"
        },
        {
          "command": "tfTools.upload",
          "when": "tfTools.uploadApplicable"
        },
        {
          "command": "tfTools.openMapFile",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "tfTools.flash",
          "when": "view == tfTools.configuration && viewItem == artifact-binary && tfTools.flashApplicable",
          "group": "inline@1",
          "enablement": "tfTools.binaryExists"
        },
        {
          "command": "tfTools.upload",
          "when": "view == tfTools.configuration && viewItem == artifact-binary && tfTools.uploadApplicable",
          "group": "inline@2",
          "enablement": "tfTools.binaryExists"
        },
        {
          "command": "tfTools.openMapFile",
          "when": "view == tfTools.configuration && viewItem == artifact-map",
          "group": "inline@1",
          "enablement": "tfTools.mapExists"
        }
      ],
      "view/title": [
        {
          "command": "tfTools.build",
          "when": "view == tfTools.configuration",
          "group": "navigation@1",
          "enablement": "!tfTools.workflowBlocked"
        },
        {
          "command": "tfTools.clippy",
          "when": "view == tfTools.configuration",
          "group": "overflow@1",
          "enablement": "!tfTools.workflowBlocked"
        },
        {
          "command": "tfTools.check",
          "when": "view == tfTools.configuration",
          "group": "overflow@2",
          "enablement": "!tfTools.workflowBlocked"
        },
        {
          "command": "tfTools.clean",
          "when": "view == tfTools.configuration",
          "group": "overflow@3",
          "enablement": "!tfTools.workflowBlocked"
        },
        {
          "command": "tfTools.refreshIntelliSense",
          "when": "view == tfTools.configuration",
          "group": "overflow@4"
        }
      ]
    },
    "configuration": {
      "title": "Trezor Firmware Tools",
      "properties": {
        "tfTools.manifestPath": {
          "type": "string",
          "default": "tf-tools-manifest.yaml",
          "description": "(Trezor) Path to the tf-tools manifest file, relative to the workspace root.",
          "scope": "resource"
        },
        "tfTools.cargoWorkspacePath": {
          "type": "string",
          "default": "core/embed",
          "description": "(Trezor) Path to the cargo workspace directory used for build tasks, relative to the workspace root. Defaults to the workspace root when empty.",
          "scope": "resource"
        },
        "tfTools.showConfigurationInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "(Trezor) Show the active build configuration in the status bar.",
          "scope": "resource"
        },
        "tfTools.artifactsPath": {
          "type": "string",
          "default": "core/build-xtask/artifacts",
          "description": "(Trezor) Absolute or workspace-relative path to the directory that contains build artifact sub-folders (e.g. compile-commands files). Defaults to 'core/build-xtask/artifacts'. Clear to disable IntelliSense artifact resolution.",
          "scope": "resource"
        },
        "tfTools.excludedFiles.grayInTree": {
          "type": "boolean",
          "default": true,
          "description": "(Trezor) Gray excluded files in the Explorer in addition to showing the exclusion badge.",
          "scope": "resource"
        },
        "tfTools.excludedFiles.showEditorOverlay": {
          "type": "boolean",
          "default": true,
          "description": "(Trezor) Show a first-line warning overlay in editors for files that are excluded from the active build configuration.",
          "scope": "resource"
        },
        "tfTools.excludedFiles.fileNamePatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["*.c"],
          "description": "(Trezor) Basename-only glob patterns (name + extension) for files eligible to be marked excluded. Case-sensitive. Subpath globbing is not supported. Excluded-file marking is disabled when this list is empty.",
          "scope": "resource"
        },
        "tfTools.excludedFiles.folderGlobs": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["core/embed/**", "core/vendor/**"],
          "description": "(Trezor) Folder glob patterns that scope excluded-file marking. May be absolute paths or paths relative to the workspace root. Use '/' separators. Excluded-file marking is disabled when this list is empty.",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run bundle -- --watch",
    "watch:tsc": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/integration/runTest.js",
    "test:unit": "mocha --ui tdd --require out/test/unit/setup.js 'out/test/unit/**/*.test.js'",
    "smoke:package": "npm run package && node ./scripts/smoke-package.cjs",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "minimatch": "^10.2.5",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.21.0",
    "mocha": "^10.8.2",
    "typescript": "^5.8.2"
  }
}
