        "monitor adapter speed 2000",
        //"add-symbol-file core/build-xtask/artifacts/latest/secmon.elf",
        "add-symbol-file core/build-xtask/artifacts/latest/firmware.elf",
        "add-symbol-file ${workspaceFolder}/sdk/apps/funnycoin-rust/target/thumbv7em-none-eabihf/debug/funnycoin_rust 0x20220080"
      ],
      "presentation": {
        "group": "STM32U5-ExtApp",
      },
      "swoConfig": {
        "enabled": true,
        "cpuFrequency": 160000000,
        "swoFrequency": 2000000,
        "source": "probe",
                "decoders": [
                    {
                        "type": "console",
                        "label": "ITM",
                        "port": 0,
                        "encoding": "ascii",
                        "logfile": "/home/pcernin/itm.log"
                    }
                ]
      }
    },
    {
      "name": "EMU - Firmware",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/core/build-xtask/artifacts/latest/firmware-emu",
      "args": ["-m", "main"],
      "cwd": "${workspaceFolder}/core/src",
      "linux": {
        "MIMode": "gdb",
        "miDebuggerPath": "gdb"
      },
      "MIMode": "lldb",
      "stopAtEntry": true,
      "presentation": {
        "group": "Emulator",
      },
    },

    {
      "name": "EMU - Prodtest",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/core/build-xtask/artifacts/latest/prodtest.elf",
      "cwd": "${workspaceFolder}/core/build/unix",
      "linux": {
        "MIMode": "gdb",
        "miDebuggerPath": "gdb"
      },
      "MIMode": "lldb",
      "stopAtEntry": true,
      "presentation": {
        "group": "Emulator",
      },
    },
    {
      "name": "EMU - Bootloader",
      "type": "cppdbg",
